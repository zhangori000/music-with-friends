{
  "name": "music-with-friends",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "vercel-build": "next build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run test:unit && npm run test:architecture && npm run test:smoke",
    "test:unit": "vitest run tests/unit tests/contracts tests/integration",
    "test:architecture": "vitest run tests/architecture",
    "test:smoke": "npm run build && node --test tests/rendered-html.test.mjs",
    "test:coverage": "vitest run --coverage tests/unit tests/contracts tests/integration tests/architecture",
    "typecheck": "tsc --noEmit",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck",
    "mobile:export": "npm --prefix apps/mobile run export:ios",
    "verify": "npm run lint && npm run typecheck && npm run vercel-build && npm run test && npm run mobile:typecheck && npm run mobile:export",
    "bench": "vitest bench benchmarks",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.46.0",
    "@cloudflare/workers-types": "5.20260722.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "22.19.19",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.29",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.11",
    "react-server-dom-webpack": "19.2.8",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vinext": "0.2.1",
    "vite": "8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "4.113.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "type": "module"
}
